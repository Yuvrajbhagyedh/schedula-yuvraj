erDiagram
    USER ||--o| PATIENT : "1-to-1 · has patient profile"
    USER ||--o| DOCTOR : "1-to-1 · has doctor profile"
    USER ||--o{ NOTIFICATION : "1-to-many · receives"
    DOCTOR ||--o{ SLOT : "1-to-many · creates"
    DOCTOR ||--o{ APPOINTMENT : "1-to-many · handles"
    PATIENT ||--o{ APPOINTMENT : "1-to-many · books"
    SLOT ||--o| APPOINTMENT : "1-to-1 · booked by"

    USER {
        uuid id PK
        string name
        string email UK
        string password_hash
        enum role "patient | doctor | admin"
        string phone
        timestamp created_at
        timestamp updated_at
    }

    PATIENT {
        uuid id PK
        uuid user_id FK "one-to-one -> USER"
        date date_of_birth
        string gender
        string address
        string blood_group
    }

    DOCTOR {
        uuid id PK
        uuid user_id FK "one-to-one -> USER"
        string specialization
        int experience_years
        string qualification
        decimal consultation_fee
        string bio
        boolean is_verified
    }

    SLOT {
        uuid id PK
        uuid doctor_id FK "many-to-one -> DOCTOR"
        date slot_date
        time start_time
        time end_time
        enum status "available | booked | blocked"
    }

    APPOINTMENT {
        uuid id PK
        uuid patient_id FK "many-to-one -> PATIENT"
        uuid doctor_id FK "many-to-one -> DOCTOR"
        uuid slot_id FK "one-to-one -> SLOT"
        enum status "booked | completed | cancelled | rescheduled"
        string reason
        timestamp created_at
        timestamp updated_at
    }

    NOTIFICATION {
        uuid id PK
        uuid user_id FK "many-to-one -> USER"
        enum type "appointment | reminder | system"
        string message
        boolean is_read
        timestamp created_at
    }
